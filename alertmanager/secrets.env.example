# Gmail address used as the SMTP sender for alert emails.
SMTP_FROM=your-gmail@gmail.com
# Gmail App Password (16-character code, not your account password).
# Generate at: myaccount.google.com → Security → 2-Step Verification → App passwords
SMTP_PASSWORD=abcdefghijklmnop
# Email address that receives alert notifications.
ALERT_EMAIL_TO=your-email@example.com
