{
    "extractor": {
        "instagram": {
            "#directory": "per profile folder (single-profile.sh); split by subcategory (posts/reels/...), and sub-group tagged posts by their author",
            "directory": {
                "subcategory == 'tagged'": [
                    "{subcategory}",
                    "{username}"
                ],
                "": [
                    "{subcategory}"
                ]
            },
            "api": "rest",
            "include": [
                "stories",
                "highlights",
                "avatar"
            ],
            "previews": true,
            "videos": true
        }
    }
}
