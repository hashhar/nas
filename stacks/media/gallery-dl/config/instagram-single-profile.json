{
    "extractor": {
        "instagram": {
            "#directory": "per profile folder (single-profile.sh); split by subcategory (posts/reels/...), and sub-group tagged posts by their author",
            "directory": {
                "subcategory == 'tagged'": [
                    "{subcategory}",
                    "{username}"
                ],
                "": [
                    "{subcategory}"
                ]
            },
            "api": "rest",
            "#include": "See https://gdl-org.github.io/docs/configuration.html#extractor-instagram-include for full list",
            "include": [
                "all"
            ],
            "previews": true,
            "videos": true
        }
    }
}
